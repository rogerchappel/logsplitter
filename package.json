{
  "name": "logsplitter",
  "version": "0.1.0",
  "description": "Local-first CLI for slicing noisy logs into searchable failure packets.",
  "type": "module",
  "bin": {
    "logsplitter": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "fixtures",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm run build && npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "prepack": "npm run build"
  },
  "keywords": [
    "logs",
    "ci",
    "cli",
    "triage",
    "failure-analysis"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/logsplitter.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/logsplitter/issues"
  },
  "homepage": "https://github.com/rogerchappel/logsplitter#readme"
}
