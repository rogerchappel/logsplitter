{
  "name": "logsplitter",
  "version": "0.1.0",
  "description": "Local-first CLI for slicing noisy logs into searchable failure packets.",
  "type": "module",
  "bin": {
    "logsplitter": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "fixtures",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "logs",
    "ci",
    "cli",
    "triage",
    "failure-analysis"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
